					39 00 00 40 00 00 06 F0 55 AA 52 08 00
					// 3pulse
					39 00 00 40 00 00 02 6F 13
					39 00 00 40 00 00 02 B2 42
					// 4pulse
					39 00 00 40 00 00 02 6F 12
					39 00 00 40 00 00 02 B2 03
				];

				t2m,mdss-dsi-set-10hz-mode-command = [
					// Skip mode setting
					39 00 00 40 00 00 06 F0 55 AA 52 08 00
					// LP_MODE=1
					39 00 00 40 00 00 02 6F 1B
					39 00 00 40 00 00 02 BA 18
					// Skip frame Seq1
					39 00 00 40 00 00 02 6F 1C
					39 00 00 40 00 00 11 BA 01 01 01 01 0B 00 00 00 0B 00 00 00 00 00 00 00
					39 00 00 40 00 00 02 2F 02
					39 00 00 40 00 00 02 5A 01
					39 00 00 40 00 00 02 2F 30
					39 00 00 40 00 00 02 6D 06
				];

				qcom,mdss-dsi-off-command = [
					39 00 00 00 14 00 02 28 00
					39 00 00 00 78 00 02 10 00
				];

				qcom,mdss-dsi-timing-switch-command = [
					// Skip mode setting
					39 00 00 40 00 00 06 F0 55 AA 52 08 00
					// LP_MODE=1
					39 00 00 40 00 00 02 6F 1B
					39 00 00 40 00 00 02 BA 18
					// Skip frame Seq1
					39 00 00 40 00 00 02 6F 1C
					39 00 00 40 00 00 11 BA 01 01 01 01 0B 00 00 00 0B 00 00 00 00 00 00 00
					39 00 00 40 00 00 02 2F 02
					39 00 00 40 00 00 02 5A 01
					39 00 00 40 00 00 02 2F 30
					39 00 00 40 00 00 02 6D 06
				];

				qcom,mdss-dsi-on-command-state = "dsi_lp_mode";
				qcom,mdss-dsi-off-command-state = "dsi_hs_mode";
				t2m,mdss-dsi-dbv-lower-bl1290-mode-command-state = "dsi_hs_mode";
				t2m,mdss-dsi-dbv-higher-bl1290-mode-command-state = "dsi_hs_mode";
				t2m,mdss-dsi-set-1hz-mode-command-state = "dsi_hs_mode";
				qcom,mdss-dsi-timing-switch-command-state = "dsi_hs_mode";

				qcom,mdss-dsi-h-sync-pulse = <0>;
				qcom,compression-mode = "dsc";
				qcom,mdss-dsc-version = <0x11>;
				qcom,mdss-dsc-scr-version = <0x0>;
				qcom,mdss-dsc-slice-height = <12>;
				qcom,mdss-dsc-slice-width = <558>;
				qcom,mdss-dsc-slice-per-pkt = <2>;
				qcom,mdss-dsc-bit-per-component = <10>;
				qcom,mdss-dsc-bit-per-pixel = <8>;
				qcom,mdss-dsc-block-prediction-enable;
			};
		};
	};
};


